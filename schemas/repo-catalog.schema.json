{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/repo-catalog.schema.json",
  "type": "object",
  "required": ["version", "repos"],
  "properties": {
    "version": { "type": "integer" },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "org", "repo", "defaultBranch", "governanceMode", "active"],
        "properties": {
          "id": { "type": "string" },
          "org": { "type": "string" },
          "repo": { "type": "string" },
          "defaultBranch": { "type": "string" },
          "stack": { "type": "array", "items": { "type": "string" } },
          "usesVersioningFolder": { "type": "boolean" },
          "governanceMode": { "type": "string", "enum": ["subtree", "copy"] },
          "active": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  }
}
